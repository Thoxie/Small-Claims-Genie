# Small Claims Genie — Required Environment Variables
# Copy this file as reference when restoring to a new Replit project.
# Set each of these as Secrets in the Replit Secrets panel (NOT in a .env file).

# ── Clerk Authentication ────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Session ─────────────────────────────────────────────────────────────────
# Any long random string (32+ characters). Generate one at passwordsgenerator.net
SESSION_SECRET=replace_with_random_32_char_string

# ── Database ─────────────────────────────────────────────────────────────────
# Set automatically when you provision a PostgreSQL database in Replit.
# In Replit: click the Database icon in the left sidebar → Create Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

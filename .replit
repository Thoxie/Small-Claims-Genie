modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server-build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server-lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "frontend-lint"

[[workflows.workflow]]
name = "api-server-build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-server-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-server-lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "frontend-lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/small-claims-genie run lint"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
VITE_CLERK_PUBLISHABLE_KEY_DEV = "pk_test_d2lzZS1tYXJsaW4tNTAuY2xlcmsuYWNjb3VudHMuZGV2JA"
